# API + Auth
# Backend server URL — change this single var to switch between local and production
VITE_API_SERVER=http://localhost:3600
# VITE_API_SERVER=https://api.360ghar.com
VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Google sign-in uses the Supabase OAuth *redirect* flow — NO client env var is
# required. Configure the Google provider in the Supabase dashboard and add this
# origin's /auth/callback to the Supabase Redirect URL allowlist.
#
# Required dashboard configuration for Google OAuth (else you get a
# "redirect_uri_mismatch" error):
#
# 1) Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#      http://localhost:5173/auth/callback   (local dev)
#      https://360ghar.com/auth/callback     (production)
#    (Add any other origin you deploy on, e.g. deploy-preview URLs.)
#
# 2) Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
#    ID → Authorized redirect URIs:
#      https://<project-ref>.supabase.co/auth/v1/callback
#    where <project-ref> is your Supabase project reference (Supabase Dashboard
#    → Project Settings → Reference ID). This is the URL Google redirects back
#    to after consent; Supabase then forwards to the app's /auth/callback.
#
# (Optional, follow-up only) Google One-Tap would need:
# VITE_GOOGLE_OAUTH_CLIENT_ID=
#
# Override the Google OAuth redirect URL base (defaults to window.location.origin;
# a leading "www." is stripped so www visitors match the non-www allowlist).
# Set this for Docker / reverse-proxy setups where the browser origin differs.
# Example: VITE_AUTH_REDIRECT_URL=http://localhost:3000
# VITE_AUTH_REDIRECT_URL=

# Google Places API Key
VITE_GOOGLE_PLACES_API_KEY=

# Build-time sitemap generation
# The properties sitemap is cached to .build-cache/ for 12h to avoid re-crawling
# the backend on every local build (mirrors the backend search-cache TTL).
# Set to "1" to bypass the cache (e.g. to pick up newly created properties),
# or simply delete the .build-cache/ directory. Netlify builds are unaffected
# (ephemeral containers always start with a cold cache).
# BUILD_CACHE_DISABLED=1

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
